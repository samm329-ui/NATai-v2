# =============================================================================
# N.A.T. AI Assistant - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values. Never commit .env to git.
# All settings below are optional except GROQ_API_KEY (required for chat).
# =============================================================================

# ==============================
# GROQ API (Required for chat)
# ==============================
# Get your key at https://console.groq.com
# You can use multiple Groq API keys: set GROQ_API_KEY_2, GROQ_API_KEY_3, etc.

GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEY_2=
GROQ_API_KEY_3=

# ==============================
# GROQ Model (Optional)
# ==============================
GROQ_MODEL=llama-3.3-70b-versatile

# ==============================
# External APIs (Optional)
# ==============================
TAVILY_API_KEY=
ALPHA_VANTAGE_KEY=
FMP_KEY=
NEWS_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
SERPAPI_KEY=

# ==============================
# Text-to-Speech (Optional)
# ==============================
TTS_VOICE=en-US-AriaNeural
TTS_RATE=+0%

# ==============================
# Branding (Optional)
# ==============================
ASSISTANT_NAME=Natasha
JARVIS_USER_TITLE=Boss
